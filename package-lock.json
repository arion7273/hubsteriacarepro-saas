{
  "name": "hubsteriacarepro-saas",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "hubsteriacarepro-saas",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
      }
    },
    "apps/api": {
      "name": "@hubsteriacarepro/api",
      "version": "0.1.0",
      "dependencies": {
        "@hubsteriacarepro/domain": "file:../../packages/domain"
      }
    },
    "apps/web": {
      "name": "@hubsteriacarepro/web",
      "version": "0.1.0"
    },
    "node_modules/@hubsteriacarepro/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@hubsteriacarepro/domain": {
      "resolved": "packages/domain",
      "link": true
    },
    "node_modules/@hubsteriacarepro/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/domain": {
      "name": "@hubsteriacarepro/domain",
      "version": "0.1.0"
    }
  }
}
